name                         = "economist-radio"
aws_region                   = "eu-west-2"
vpc_id                       = "vpc-xxxxxxxx"
public_subnet_ids            = ["subnet-public-a", "subnet-public-b"]
private_subnet_ids           = ["subnet-private-a", "subnet-private-b"]
certificate_arn              = "arn:aws:acm:eu-west-2:123456789012:certificate/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
domain_name                  = "radio.example.com"
image_uri                    = "123456789012.dkr.ecr.eu-west-2.amazonaws.com/economist-radio:latest"
content_bucket               = "economist-radio-source"
content_prefix               = "radio-source"
stream_mirror_bucket         = ""
stream_mirror_prefix         = "radio/live"
okta_issuer                  = "https://your-org.okta.com/oauth2/default"
okta_authorization_endpoint  = "https://your-org.okta.com/oauth2/default/v1/authorize"
okta_token_endpoint          = "https://your-org.okta.com/oauth2/default/v1/token"
okta_user_info_endpoint      = "https://your-org.okta.com/oauth2/default/v1/userinfo"
okta_client_id               = "your-okta-client-id"
okta_client_secret_secret_id = "arn:aws:secretsmanager:eu-west-2:123456789012:secret:okta-radio-client-secret"
